# KHU App — Environment Variables Template
# Copy this file to ".env" and fill in real values.
# NEVER commit the actual ".env" file to GitHub — it's already in .gitignore.

# Push Notifications (Web Push / VAPID)
# Generate your own keypair with:
#   python -c "from py_vapid import Vapid02; v=Vapid02(); v.generate_keys(); print(v.private_pem().decode())"
VAPID_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----
YOUR_KEY_HERE
-----END PRIVATE KEY-----"
VAPID_PUBLIC_KEY_B64URL="your-public-key-here"
VAPID_CONTACT_EMAIL="your-email@example.com"
