# KHU App — Environment Variables Template
# Copy this file to ".env" and fill in real values.
# NEVER commit the actual ".env" file to GitHub — it's already in .gitignore.

# Push Notifications (Web Push / VAPID)
#
# IMPORTANT: VAPID_PRIVATE_KEY_RAW_B64URL must be the RAW private key
# bytes, base64url-encoded — NOT a PEM block with "-----BEGIN..." headers.
# Generate a correct keypair with:
#
#   python -c "
#   from py_vapid import Vapid02
#   import base64
#   v = Vapid02(); v.generate_keys()
#   raw = v.private_key.private_numbers().private_value.to_bytes(32, 'big')
#   print('PRIVATE:', base64.urlsafe_b64encode(raw).decode().rstrip('='))
#   pub = v.public_key.public_bytes(
#       encoding=__import__('cryptography.hazmat.primitives.serialization', fromlist=['Encoding']).Encoding.X962,
#       format=__import__('cryptography.hazmat.primitives.serialization', fromlist=['PublicFormat']).PublicFormat.UncompressedPoint
#   )
#   print('PUBLIC:', base64.urlsafe_b64encode(pub).decode().rstrip('='))
#   "
VAPID_PRIVATE_KEY_RAW_B64URL="your-raw-base64url-private-key-here"
VAPID_PUBLIC_KEY_B64URL="your-public-key-here"
VAPID_CONTACT_EMAIL="your-email@example.com"
